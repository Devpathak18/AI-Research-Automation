# Copy this file to .env and fill in your own values.
# This project mainly configures things inside Make.com directly,
# but keep these on hand for setup / reference.

# ngrok URL exposing your local Ollama instance (changes on free tier every restart)
OLLAMA_NGROK_URL='YOUR_NGROK_UR';

# Ollama model used for all pipeline steps
OLLAMA_MODEL=qwen2.5:0.5b

# Make.com webhook URL that triggers the scenario (paste into index.html)
const WEBHOOK_URL = 'YOUR_MAKE_WEBHOOK_URL'; 

# Google Drive folder ID where compiled guides are saved as Docs
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
